# MNEMONIC is auto-provided by EigenCloud KMS — do not set manually
BACKEND_URL=https://api.yourdomain.com
SKILL_REGISTRY_URL=https://raw.githubusercontent.com/38d3b7/eigenskills/main/registry/registry.json
EIGENAI_GRANT_API=https://determinal-api.eigenarcade.com
AGENT_MODEL=meta-llama/Llama-3.3-70B-Instruct
AGENT_MAX_TOKENS=1024
AGENT_MAX_TURNS=6
PORT=3000

# Marketplace (injected by backend at deploy)
MARKETPLACE_URL=https://yourdomain.com

# RPC endpoints (defaults to public RPCs if not set)
RPC_URL_SEPOLIA=https://rpc.sepolia.org
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
RPC_URL_BASE=https://mainnet.base.org
RPC_URL_MAINNET=https://eth.llamarpc.com
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_URL_OPTIMISM=https://mainnet.optimism.io
RPC_URL_POLYGON=https://polygon-rpc.com

# Wallet safety limit (max USD per single ERC-20 transfer)
WALLET_MAX_TRANSFER_USD=100
