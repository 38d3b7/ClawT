# Platform EigenCompute credentials
EIGENCOMPUTE_PRIVATE_KEY=0x_your_private_key
EIGENCOMPUTE_ENVIRONMENT=sepolia

# Agent Docker image (pushed to Docker Hub)
AGENT_IMAGE_REF=your_dockerhub_username/clawt-agent:latest

# Public URL of this backend (for agent callbacks)
BACKEND_PUBLIC_URL=https://api.yourdomain.com

# Frontend URL (CORS + injected as MARKETPLACE_URL into agent)
FRONTEND_URL=https://yourdomain.com

# Server port
PORT=3002

# Session token secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_SECRET=

# Skill registry URL
SKILL_REGISTRY_URL=https://raw.githubusercontent.com/38d3b7/eigenskills/main/registry/registry.json
